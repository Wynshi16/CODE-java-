import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        // đọc số lượng test case
        int t = Integer.parseInt(sc.nextLine());
        
        // đọc và in từng dòng
        for (int i = 0; i < t; i++) {
            String line = sc.nextLine();
            System.out.println(line);
        }
        
        sc.close();
    }
}
