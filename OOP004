import java.util.Scanner;

class Point {
    private int x;
    private int y;

    // Constructor
    public Point(int x, int y) {
        this.x = x;
        this.y = y;
    }

    // (1) Getters và Setters
    public int getX() {
        return x;
    }

    public void setX(int x) {
        this.x = x;
    }

    public int getY() {
        return y;
    }

    public void setY(int y) {
        this.y = y;
    }

    // (2) Hàm move(dx, dy)
    public void move(int dx, int dy) {
        this.x += dx;
        this.y += dy;
    }

    // (3) Hàm distanceTo(Point p)
    public double distanceTo(Point p) {
        int dx = p.getX() - this.x;
        int dy = p.getY() - this.y;
        return Math.sqrt(dx * dx + dy * dy);
    }
}

// (4) Main class
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int t = Integer.parseInt(sc.nextLine().trim()); // số lượng test case

        for (int i = 0; i < t; i++) {
            int x1 = sc.nextInt();
            int y1 = sc.nextInt();
            int x2 = sc.nextInt();
            int y2 = sc.nextInt();

            Point A = new Point(x1, y1);
            Point B = new Point(x2, y2);

            // Di chuyển A (1,1)
            A.move(1, 1);

            // Tính và in khoảng cách giữa A và B (format 2 chữ số)
            double distance = A.distanceTo(B);
            System.out.printf("%.2f%n", distance);
        }

        sc.close();
    }
}
