import java.util.*;

class NotContainVowelException extends Exception {
    public NotContainVowelException(String message) {
        super(message);
    }
}

public class Main {

    // Hàm kiểm tra chuỗi có chứa nguyên âm hay không
    public static void checkVowels(String str) throws NotContainVowelException {
        if (str.matches(".*[aeiouAEIOU].*")) {
            System.out.println("String has vowels");
        } else {
            throw new NotContainVowelException("String not contain vowels");
        }
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int N = Integer.parseInt(sc.nextLine());

        for (int i = 0; i < N; i++) {
            String input = sc.nextLine();
            try {
                checkVowels(input);
            } catch (NotContainVowelException e) {
                System.out.println(e.getMessage());
            }
        }
    }
}
