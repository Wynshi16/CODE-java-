import java.util.Scanner;

// (1) Class Amount
class Amount {
    private String currency;
    private int amount;

    public Amount(String currency, int amount) {
        this.currency = currency;
        this.amount = amount;
    }

    public int add(Amount other) throws Exception {
        if (!this.currency.equals(other.currency)) {
            throw new Exception("Currency doesn't match");
        }
        return this.amount + other.amount;
    }
}

// (2) Main class
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int t = Integer.parseInt(sc.nextLine().trim()); // số lượng test case

        for (int i = 0; i < t; i++) {
            String currency1 = sc.next();
            int amount1 = sc.nextInt();
            String currency2 = sc.next();
            int amount2 = sc.nextInt();

            Amount a1 = new Amount(currency1, amount1);
            Amount a2 = new Amount(currency2, amount2);

            try {
                int sum = a1.add(a2);
                System.out.println(sum);
            } catch (Exception e) {
                System.out.println(e.getMessage());
            }
        }

        sc.close();
    }
}
