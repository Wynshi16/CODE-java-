class Person {
    private String name;
    private String address;

    public Person(String name, String address) {
        this.name = name;
        this.address = address;
    }

    public String getName() {
        return name;
    }

    public String getAddress() {
        return address;
    }

    @Override
    public String toString() {
        return name + " - " + address;
    }
}

class Student extends Person {
    private int credits;
    private int studentID;

    public Student(String name, String address, int studentID) {
        super(name, address);
        this.studentID = studentID;
        this.credits = 0;
    }

    public void study() {
        credits++;
    }

    public int credits() {
        return credits;
    }
}

public class Main {
    public static void main(String[] args) {
        Student student = new Student("Ollie", "6381 Hollywood Blvd. Los Angeles 90028", 12345);
        System.out.println(student.toString());
        System.out.println("Study credits " + student.credits());
        student.study();
        System.out.println("Study credits " + student.credits());
    }
}
